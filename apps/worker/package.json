{
  "name": "@sovereign/worker",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "auth:prepare": "node ./scripts/apply-auth-consistency.mjs",
    "predev": "pnpm auth:prepare",
    "dev": "wrangler dev --port 8787",
    "predeploy": "pnpm auth:prepare",
    "deploy": "wrangler deploy",
    "prebuild": "pnpm auth:prepare",
    "build": "pnpm typecheck",
    "pretypecheck": "pnpm auth:prepare",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "pretest": "pnpm auth:prepare",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@cloudflare/workers-types": "^4.20260515.0",
    "@vitest/ui": "4.1.8",
    "typescript": "^5.5.4",
    "vitest": "4.1.8",
    "wrangler": "^4.105.0"
  },
  "dependencies": {
    "@sovereign/core": "file:../../packages/core",
    "itty-router": "^5.0.23",
    "zod": "^4.1.5"
