#######################################################################
# SOVV Monorepo Environment Configuration
# Copy to .env.local and fill in your values
#######################################################################

# CLOUDFLARE ACCOUNT & AUTHENTICATION
# ====================================
CLOUDFLARE_ACCOUNT_ID=8b1954d216d65077c6480d62583fe2c2
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CF_ACCOUNT_ID=8b1954d216d65077c6480d62583fe2c2

# NEXT.JS / WEB FRONTEND
# ======================
NODE_ENV=development
# Must be set to production for optimized builds
# NEXT_PUBLIC_API_URL=https://api.defrag.app

# Turnstile CAPTCHA (required for form protection)
# Get from: https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAADhGIF8-iOLIg8MU
TURNSTILE_SECRET_KEY=your_turnstile_secret_here

# CLOUDFLARE WORKERS (API)
# ========================
# Database bindings (managed in wrangler.toml, these are for local dev)
# D1_DATABASE_ID=c8c2fd8d-5297-46fc-8594-7629c8bad74d

# KV Namespace for session state, cache, replay protection
# KV_NAMESPACE_ID=3bd3ff5048a8468e82c574d7d66045c3

# R2 Bucket for templates and artifacts
# R2_BUCKET_NAME=vibesdk-templates
# R2_ACCESS_KEY_ID=your_r2_access_key
# R2_SECRET_ACCESS_KEY=your_r2_secret_key

# WORKER INTER-SERVICE COMMUNICATION
# ====================================
# These workers call each other for AI inference and session management
# AI_SERVICE_URL=https://worker-ai.defrag.workers.dev
# SESSION_SERVICE_URL=https://worker-session.defrag.workers.dev

# LLM / AI MODELS
# ===============
# Used by worker-ai for inference
# ANTHROPIC_API_KEY=your_anthropic_key_here (if using Anthropic)
# OPENAI_API_KEY=your_openai_key_here (if using OpenAI)

# BILLING & WEBHOOKS
# ==================
# Stripe webhook signing key for billing events
# STRIPE_WEBHOOK_SECRET=whsec_test_your_secret_here
# BILLING_RATE_LIMIT_REQUESTS=100
# BILLING_RATE_LIMIT_WINDOW_MS=60000

# RATE LIMITING & ABUSE PROTECTION
# ==================================
# Global rate limits
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# Per-user/IP rate limits
USER_RATE_LIMIT_REQUESTS_PER_MINUTE=30
USER_RATE_LIMIT_REQUESTS_PER_HOUR=500

# Request validation
MAX_REQUEST_SIZE_MB=10
MAX_PROMPT_LENGTH=5000
MAX_MEMORY_ITEMS=500

# LOGGING & OBSERVABILITY
# =======================
LOG_LEVEL=info
# Options: debug, info, warn, error
# ENABLE_ANALYTICS=true

# DEVELOPMENT ONLY
# ================
# Enable debug logging
# DEBUG=*
# Wrangler development settings
# WRANGLER_MINIFY=false
