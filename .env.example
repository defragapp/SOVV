# Shared local defaults
NODE_ENV=development
PORT=5050
BASE_PATH=/
API_TARGET=http://localhost:5050

# API runtime
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sovv
LOG_LEVEL=info
ALLOWED_ORIGINS=http://localhost:5173
APP_ORIGIN=http://localhost:5173

# Security (set strong random values in production)
RESET_TOKEN_SECRET=change-me-to-a-long-random-string

# Optional billing — Stripe (set as Cloudflare Worker secrets in production)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=                  # Legacy / default price ID (fallback)
STRIPE_ALIGNMENT_PRICE_ID=        # Alignment-tier subscription price ID
STRIPE_COVENANT_PRICE_ID=         # Covenant-tier subscription price ID

# KMS — AES-256-GCM encryption for Covenant pro tier
# Generate: openssl rand -hex 32
# Deploy:   wrangler secret put KMS_ENCRYPTION_KEY
KMS_ENCRYPTION_KEY=               # 64-char lowercase hex string (32 bytes)

# Frontend build/runtime (Vite)
VITE_STRIPE_PRO_PRICE_ID=
VITE_TURNSTILE_SITE_KEY=
VITE_HERO_VIDEO_MP4=
VITE_HERO_VIDEO_WEBM=
VITE_MARKETING_BG_STYLE=editorial
VITE_MARKETING_BG_VIDEO_MP4=
VITE_MARKETING_BG_VIDEO_WEBM=
